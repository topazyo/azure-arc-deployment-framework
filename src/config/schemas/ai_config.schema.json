{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/topazyo/azure-arc-deployment-framework/schemas/ai_config.schema.json",
  "title": "Azure Arc AI Configuration Schema",
  "description": "Configuration schema for the Azure Arc Predictive Toolkit AI components",
  "type": "object",
  "required": ["aiComponents"],
  "properties": {
    "aiComponents": {
      "type": "object",
      "description": "Root container for all AI component configurations",
      "required": ["model_config"],
      "properties": {
        "predictionEngine": {
          "$ref": "#/$defs/predictionEngine"
        },
        "monitoring": {
          "$ref": "#/$defs/monitoring"
        },
        "feature_engineering": {
          "$ref": "#/$defs/featureEngineering"
        },
        "model_config": {
          "$ref": "#/$defs/modelConfig"
        },
        "pattern_analyzer_config": {
          "$ref": "#/$defs/patternAnalyzerConfig"
        },
        "remediation_learner_config": {
          "$ref": "#/$defs/remediationLearnerConfig"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "predictionEngine": {
      "type": "object",
      "description": "Prediction engine patterns and clustering configuration",
      "properties": {
        "patterns": {
          "type": "object",
          "description": "Named pattern definitions for health analysis",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "metrics": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of metric names to monitor"
              },
              "thresholds": {
                "type": "object",
                "description": "Threshold values for metrics",
                "additionalProperties": { "type": "number" }
              }
            }
          }
        },
        "clustering": {
          "type": "object",
          "description": "DBSCAN clustering parameters",
          "properties": {
            "eps": {
              "type": "number",
              "description": "DBSCAN epsilon (neighborhood distance)",
              "default": 0.5,
              "minimum": 0
            },
            "min_samples": {
              "type": "integer",
              "description": "Minimum samples per cluster",
              "default": 5,
              "minimum": 1
            }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "description": "Monitoring configuration for AMA and other agents",
      "properties": {
        "ama": {
          "type": "object",
          "properties": {
            "healthChecks": {
              "type": "object",
              "properties": {
                "frequency": {
                  "type": "string",
                  "description": "Health check frequency (e.g., '5m', '1h')",
                  "pattern": "^[0-9]+[smhd]$"
                },
                "metrics": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "alerts": {
              "type": "object",
              "properties": {
                "dataCollection": {
                  "type": "object",
                  "properties": {
                    "lossThreshold": { "type": "number" },
                    "latencyThreshold": { "type": "number" }
                  }
                },
                "performance": {
                  "type": "object",
                  "properties": {
                    "cpuThreshold": { "type": "number", "minimum": 0, "maximum": 100 },
                    "memoryThreshold": { "type": "number", "minimum": 0, "maximum": 100 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "featureEngineering": {
      "type": "object",
      "description": "Feature engineering configuration",
      "properties": {
        "rolling_window": {
          "type": "integer",
          "description": "Rolling window size for feature calculations",
          "default": 5,
          "minimum": 1
        },
        "rolling_window_sizes": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "description": "Multiple rolling window sizes"
        },
        "lags": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "description": "Lag periods for feature creation",
          "default": [1, 3, 5]
        },
        "selected_k_features": {
          "type": "integer",
          "description": "Number of top features to select",
          "default": 20,
          "minimum": 1
        },
        "k_best_features": {
          "type": "integer",
          "description": "Alias for selected_k_features",
          "minimum": 1
        },
        "feature_selection_k": {
          "type": "integer",
          "description": "Alias for selected_k_features",
          "minimum": 1
        },
        "numerical_nan_fill_strategy": {
          "type": "string",
          "enum": ["mean", "median", "zero", "drop"],
          "default": "mean"
        },
        "categorical_nan_fill_strategy": {
          "type": "string",
          "enum": ["unknown", "mode", "drop"],
          "default": "unknown"
        }
      }
    },
    "modelConfig": {
      "type": "object",
      "description": "ML model configuration including features and hyperparameters",
      "required": ["features", "models"],
      "properties": {
        "features": {
          "type": "object",
          "description": "Feature definitions per model type",
          "properties": {
            "health_prediction": {
              "$ref": "#/$defs/featureDefinition"
            },
            "anomaly_detection": {
              "$ref": "#/$defs/featureDefinition"
            },
            "failure_prediction": {
              "$ref": "#/$defs/featureDefinition"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/featureDefinition"
          }
        },
        "models": {
          "type": "object",
          "description": "Model hyperparameters per model type",
          "properties": {
            "health_prediction": {
              "$ref": "#/$defs/modelHyperparameters"
            },
            "anomaly_detection": {
              "type": "object",
              "properties": {
                "contamination": {
                  "type": "number",
                  "description": "Expected proportion of anomalies",
                  "minimum": 0,
                  "maximum": 0.5,
                  "default": 0.05
                }
              }
            },
            "failure_prediction": {
              "$ref": "#/$defs/modelHyperparameters"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "featureDefinition": {
      "type": "object",
      "description": "Feature configuration for a specific model type",
      "required": ["required_features"],
      "properties": {
        "required_features": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of required feature names"
        },
        "missing_strategy": {
          "type": "string",
          "enum": ["mean", "median", "zero", "drop"],
          "default": "mean",
          "description": "Strategy for handling missing values"
        },
        "target_column": {
          "type": "string",
          "description": "Name of the target column for supervised models"
        }
      }
    },
    "modelHyperparameters": {
      "type": "object",
      "description": "Hyperparameters for ML models",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["RandomForestClassifier", "GradientBoostingClassifier", "IsolationForest"],
          "description": "ML algorithm to use"
        },
        "n_estimators": {
          "type": "integer",
          "minimum": 1,
          "default": 100
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1
        },
        "random_state": {
          "type": "integer"
        },
        "class_weight": {
          "type": "string",
          "enum": ["balanced", "balanced_subsample"]
        },
        "learning_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "subsample": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "random_forest_params": {
          "type": "object",
          "description": "RandomForest-specific parameters",
          "additionalProperties": true
        },
        "gradient_boosting_params": {
          "type": "object",
          "description": "GradientBoosting-specific parameters",
          "additionalProperties": true
        }
      }
    },
    "patternAnalyzerConfig": {
      "type": "object",
      "description": "Pattern analyzer configuration",
      "properties": {
        "dbscan_eps": {
          "type": "number",
          "minimum": 0,
          "default": 0.5
        },
        "dbscan_min_samples": {
          "type": "integer",
          "minimum": 1,
          "default": 5
        }
      }
    },
    "remediationLearnerConfig": {
      "type": "object",
      "description": "Remediation learner configuration",
      "properties": {
        "retraining_data_threshold": {
          "type": "integer",
          "description": "Number of samples before triggering retrain",
          "minimum": 1,
          "default": 50
        },
        "log_level": {
          "type": "integer",
          "description": "Python logging level (10=DEBUG, 20=INFO, 30=WARNING)",
          "enum": [10, 20, 30, 40, 50]
        },
        "remediation_learner_context_features": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Features to log in remediation context"
        }
      }
    }
  }
}
